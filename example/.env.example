# Flask session signing key (use a long random value in production)
FLASK_SECRET_KEY=dev-only-change-me

# --- Keycloak (required) ---
KEYCLOAK_SERVER_URL=https://auth.example.com
KEYCLOAK_REALM=my-realm
KEYCLOAK_CLIENT_ID=my-flask-app
KEYCLOAK_CLIENT_SECRET=your-confidential-client-secret

# --- Keycloak (optional) ---
# KEYCLOAK_SCOPES=openid email profile
# KEYCLOAK_URL_PREFIX=/auth
# KEYCLOAK_POST_LOGIN=/
# KEYCLOAK_POST_LOGOUT=http://localhost:5000/
